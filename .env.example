# ── @aznex/service ────────────────────────────────────────────────────────────

# Port the service listens on.
PORT=3000

# SQLite database file. In Docker this lives on the aznex-data volume.
DATABASE_PATH=/app/data/aznex.db

# GitHub App credentials — required for repo access verification (the
# load-bearing security check on every ingest/read). Create a GitHub App with
# repository "Metadata: read" permission and install it on your org/repos.
GITHUB_APP_ID=
# PEM private key. Newlines may be escaped as \n when set via env.
GITHUB_APP_PRIVATE_KEY=

# How long a verified user→repo permission is cached (ms). Default 5 minutes.
REPO_ACCESS_TTL_MS=300000

# GitHub OAuth app for browser login (callback: <AZNEX_BASE_URL>/api/auth/callback/github)
GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_CLIENT_SECRET=

# better-auth session signing secret — generate with `openssl rand -hex 32`.
BETTER_AUTH_SECRET=

# Public URL of the service (Railway domain in production).
AZNEX_BASE_URL=http://localhost:3000

# Frontend origin during local dev (Vite). In production the SPA is served
# same-origin by the service, so set this to AZNEX_BASE_URL.
AZNEX_FRONTEND_ORIGIN=http://localhost:5173

# ── @aznex/worker (runs on each developer's machine, not in Docker) ──────────

# Port the local worker listens on for agent hooks.
AZNEX_WORKER_PORT=3001

# Where hook scripts send events.
AZNEX_WORKER_URL=http://localhost:3001

# Remote service the worker POSTs extracted memories to.
AZNEX_SERVICE_URL=http://localhost:3000

# Per-developer API key minted by the service (Bearer token for /v1/ingest).
AZNEX_API_KEY=
